DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/chat_app"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/chat_app"
JWT_SECRET="replace-with-a-long-random-secret"
PORT=8080

# Website origin after deployment
APP_ORIGIN="https://your-app-domain.com"
PUBLIC_API_URL="https://your-app-domain.com"
ALLOWED_ORIGINS="https://your-app-domain.com"

# Persistent writable storage mount on your host
APP_DATA_DIR="/data"

# Cheap single-instance launch mode
REDIS_ENABLED=false
CHAT_BACKUPS_ENABLED=false

# Optional Redis if you add it later
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=""

# Recommended free/cheap email option: Resend SMTP
SMTP_HOST="smtp.resend.com"
SMTP_PORT="465"
SMTP_USER="resend"
SMTP_PASS="replace-with-your-resend-api-key"
SMTP_FROM="noreply@your-domain.com"

# Optional web push
VAPID_SUBJECT="mailto:you@your-domain.com"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# Optional media/theme/avatar helper
UI_AVATAR_BASE_URL="https://ui-avatars.com/api/"
STUN_SERVER_URLS="stun:stun.l.google.com:19302"

# Optional cloud backup, leave empty for now
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_BACKUP_FOLDER="chat-backups"
