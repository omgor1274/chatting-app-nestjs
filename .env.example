DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/chat_app"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/chat_app"
JWT_SECRET="replace-with-a-long-random-secret"
PORT=8080

# Website origin after deployment
APP_ORIGIN="https://your-app-domain.com"
PUBLIC_API_URL="https://your-app-domain.com"
ALLOWED_ORIGINS="https://your-app-domain.com"
BOOTSTRAP_ADMIN_NAME="O-chat Admin"
BOOTSTRAP_ADMIN_EMAIL="admin@your-domain.com"
BOOTSTRAP_ADMIN_PASSWORD="replace-with-a-strong-admin-password"

# Persistent writable storage mount on your host
APP_DATA_DIR="/data"

# Optional: Cloudflare R2 for large chat attachments
R2_ACCOUNT_ID=""
R2_BUCKET_NAME=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_PUBLIC_BASE_URL=""
R2_PRESIGN_EXPIRES_SECONDS="900"

# Cheap single-instance launch mode
REDIS_ENABLED=false
CHAT_BACKUPS_ENABLED=false
# Auto-delete old chat data with a cron job, while keeping user login/profile data
CHAT_RETENTION_ENABLED=true
CHAT_RETENTION_DAYS="7"
CHAT_RETENTION_CRON="0 * * * *"

# Optional Redis if you add it later
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=""

# Recommended free/cheap email option: Resend SMTP
SMTP_HOST="smtp.resend.com"
SMTP_PORT="465"
SMTP_USER="resend"
SMTP_PASS="replace-with-your-resend-api-key"
SMTP_FROM="noreply@your-domain.com"

# Optional web push
VAPID_SUBJECT="mailto:you@your-domain.com"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# Optional media/theme/avatar helper
UI_AVATAR_BASE_URL="https://ui-avatars.com/api/"
STUN_SERVER_URLS="stun:stun.l.google.com:19302"

# Optional cloud backup, leave empty for now
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_BACKUP_FOLDER="chat-backups"

Better admin filters
Pending only, banned only, admins only, newest first, oldest first, last updated, and quick bulk actions.

User reports / moderation queue
Let users report spam or abuse, then admins review reports and take action from one panel.

give option to delete account , soft delete of 7 days period

Message features
Reply, react, edit, forward and forward massage will stays only once in data dont copy everytime, pin, starred messages, and delete with better history.

Better group controls
More roles like moderator, invite links, join approval, mute member, remove member history.

Notifications polish
Unread counts, mention notifications, sound preferences, quiet hours, and push notification improvements.

Admin analytics
Total users, pending approvals, bans, active chats, uploads, storage usage, retention cleanup stats.
