generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String      @id @default(uuid())
  email              String      @unique
  pendingEmail       String?     @unique
  password           String
  name               String
  avatar             String?
  emailVerified      Boolean     @default(false)
  backupEnabled      Boolean     @default(true)
  darkMode           Boolean     @default(false)
  tokenVersion       Int         @default(0)
  publicKey          String?
  publicKeyUpdatedAt DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @default(now()) @updatedAt
  authTokens         AuthToken[]
}

enum MessageType {
  TEXT
  IMAGE
  DOCUMENT
  AUDIO
}

model Message {
  id           String      @id @default(uuid())
  content      String?
  ciphertext   String?
  senderId     String
  receiverId   String
  messageType  MessageType @default(TEXT)
  fileUrl      String?
  fileName     String?
  fileMimeType String?
  fileSize     Int?
  encryptedKey String?
  iv           String?
  algorithm    String?
  isEncrypted  Boolean     @default(false)
  createdAt    DateTime    @default(now())
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model ChatRequest {
  id         String        @id @default(uuid())
  senderId   String
  receiverId String
  status     RequestStatus @default(PENDING)
  createdAt  DateTime      @default(now())
}

model PushSubscription {
  id             String   @id @default(uuid())
  userId         String
  endpoint       String   @unique
  expirationTime String?
  p256dh         String
  auth           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt
}

model ContactPreference {
  id            String   @id @default(uuid())
  ownerId       String
  contactUserId String
  nickname      String?
  chatTheme     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  @@unique([ownerId, contactUserId])
}

enum AuthTokenType {
  VERIFY_EMAIL
  VERIFY_PENDING_EMAIL
  RESET_PASSWORD
}

model AuthToken {
  id          String        @id @default(uuid())
  userId      String
  tokenHash   String        @unique
  type        AuthTokenType
  targetEmail String?
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}
